# Copy this file to bundler/.env.
# Self-hosted Transeptor ERC-4337 bundler for KiiChain Testnet Oro.

KII_RPC_URL=https://json-rpc.uno.sentry.testnet.v3.kiivalidator.com/
BUNDLER_PORT=4337
BUNDLER_MIN_BALANCE=0.01

TRANSEPTOR_ENTRYPOINT_ADDRESS=0xC3412374BEf9Ea5De79022454c1802A5a58fB2B3
TRANSEPTOR_BENEFICIARY=0xYOUR_BUNDLER_WALLET_ADDRESS
TRANSEPTOR_MNEMONIC=your twelve or twenty four word testnet bundler mnemonic
TRANSEPTOR_LOG_LEVEL=info
