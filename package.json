{
  "name": "kiiflow-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "hardhat": "hardhat",
    "compile": "hardhat compile",
    "deploy:entrypoint:kii": "hardhat run --network kiiChainTestnet scripts/deploy-entrypoint.ts",
    "deploy:paymaster:kii": "hardhat run --network kiiChainTestnet scripts/deploy-paymaster-core.ts",
    "deploy:account-factory:kii": "hardhat run --network kiiChainTestnet scripts/deploy-account-factory.ts",
    "deploy:lock-vault:kii": "hardhat run --network kiiChainTestnet scripts/deploy-lock-vault.ts",
    "configure:paymaster:tokens": "hardhat run --network kiiChainTestnet scripts/configure-paymaster-tokens.ts",
    "paymaster:topup": "hardhat run --network kiiChainTestnet scripts/top-up-paymaster.ts",
    "paymaster:check": "hardhat run --network kiiChainTestnet scripts/check-paymaster-readiness.ts",
    "deploy:kii": "hardhat run --network kiiChainTestnet scripts/deploy.ts",
    "bundler:init": "ts-node scripts/init-bundler-env.ts",
    "bundler:up": "docker compose --env-file bundler/.env -f bundler/docker-compose.yml up -d",
    "bundler:logs": "docker compose --env-file bundler/.env -f bundler/docker-compose.yml logs -f",
    "bundler:down": "docker compose --env-file bundler/.env -f bundler/docker-compose.yml down",
    "bundler:source:install": "git clone https://github.com/transeptorlabs/transeptor-bundler.git bundler/source/transeptor-bundler && cd bundler/source/transeptor-bundler && corepack yarn install",
    "bundler:source:run": "scripts\\run-transeptor-source.cmd",
    "bundler:check": "ts-node scripts/check-bundler.ts",
    "bundler:check:public": "ts-node scripts/check-public-bundler.ts",
    "verify": "ts-node scripts/verify.ts",
    "export-abis": "npx hardhat compile && npx ts-node scripts/export-abis.ts",
    "test": "hardhat test"
  },
  "dependencies": {
    "@account-abstraction/contracts": "^0.8.0",
    "@kiichain/kiijs-evm": "^0.5.1",
    "@openzeppelin/contracts": "^5.6.1",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "ethers": "^6.16.0",
    "framer-motion": "^12.39.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^2.4.0",
    "viem": "^2.50.4",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "hardhat": "^2.18.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.3"
  }
}
